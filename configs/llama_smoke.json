{
  "_comment": "Cheap llama.cpp smoke test: Qwen2.5-0.5B (491 MB GGUF) on a T4. Validates the orchestration path (install wheel -> download GGUF -> serve :8000 -> onboard OpenClaw -> infer) fast and tiny, before committing to the 9B. Mirrors configs/smoke_test_tiny.json but on the llama.cpp backend.",
  "model": {
    "id": "Qwen2.5-0.5B",
    "gguf_repo": "Qwen/Qwen2.5-0.5B-Instruct-GGUF",
    "gguf_file": "qwen2.5-0.5b-instruct-q4_k_m.gguf"
  },
  "serve": {
    "backend": "llama_cpp",
    "host": "127.0.0.1",
    "port": 8000,
    "startup_timeout_seconds": 600,
    "llama_cpp": {
      "wheel": "llama-cpp-python[server]==0.3.29",
      "wheel_index": "https://abetlen.github.io/llama-cpp-python/whl/cu124",
      "server_args": ["--n_gpu_layers", "99", "--n_ctx", "4096"]
    }
  },
  "openclaw": {
    "install": true,
    "provider_id": "vllm",
    "gateway_port": 18789,
    "compat": {
      "requiresStringContent": true,
      "supportsTools": false,
      "maxTokens": 512,
      "contextWindow": 4096
    }
  }
}
